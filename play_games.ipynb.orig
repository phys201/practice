   ],
   "source": [
    "rolls = [games.roll_a_die(6) for i in range(1000)]\n",
    "plt.hist(rolls, bins=[-0.5, 0.5, 1.5, 2.5, 3.5, 4.5, 5.5])\n",
    "<<<<<<< local\n",
    "print('merge conflict 1')\n",
    "=======\n",
    "print('purposeful problem 2')\n",
    ">>>>>>> remote"
   ]
  },
  {
